{
  "name": "concarte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm generate:theme && next dev",
    "build": "pnpm generate:theme && next build",
    "start": "next start",
    "generate:theme": "tsx scripts/generate-theme-css.ts",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@tailwindcss/typography": "^0.5.15",
    "fuse.js": "^7.0.0",
    "next": "15.5.6",
    "next-intl": "^4.3.12",
    "ol": "^10.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "svg-pathdata": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/unist": "^3.0.3",
    "eslint": "^9.38.0",
    "eslint-config-next": "15.5.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "unist-util-visit": "^5.0.0"
  },
  "lint-staged": {
    "*": [
      "eslint --no-warn-ignored --max-warnings=0",
      "prettier --write --ignore-unknown"
    ]
  }
}
